# =============================================================================
# Database
# =============================================================================
# SQLite (desenvolvimento local):
# DATABASE_URL=sqlite:///app/database/ecommerce.db
# PostgreSQL (produção / Docker):
DATABASE_URL=postgresql+psycopg2://icomerce:icomerce_secret@db:5432/icomerce_db

# =============================================================================
# JWT
# =============================================================================
JWT_SECRET=icomerce-super-secret-key-change-in-production
JWT_EXPIRATION_HOURS=24

# =============================================================================
# Email altere MAIL_BACKEND para 'smtp' e configure as variáveis abaixo para usar email real
# =============================================================================
MAIL_BACKEND=console
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_NAME=iCommerce
MAIL_FROM_ADDRESS=noreply@icomerce.com

# =============================================================================
# Admin Seed (para criar o primeiro admin via python -m app.create_admin)
# =============================================================================
ADMIN_EMAIL=admin@icomerce.com
ADMIN_PASSWORD=Admin@1234
ADMIN_NAME=Admin
# ADMIN_ADDRESS=opcional